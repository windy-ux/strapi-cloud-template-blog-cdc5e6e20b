{
  "kind": "collectionType",
  "collectionName": "paintings",
  "info": {
    "singularName": "painting",
    "pluralName": "paintings",
    "displayName": "Painting",
    "description": "An artwork with title, description, year, and image"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "year": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    }
  }
}
